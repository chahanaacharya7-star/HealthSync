<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee
         https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <error-page>
        <error-code>404</error-code>
        <location>/error.jsp</location>
    </error-page>
    <error-page>
        <error-code>403</error-code>
        <location>/error.jsp</location>
    </error-page>
    <error-page>
        <error-code>500</error-code>
        <location>/error.jsp</location>
    </error-page>

    <!-- Auth Filter - protects pages that need login -->
    <filter>
        <filter-name>AuthFilter</filter-name>
        <filter-class>com.healthsync.filter.AuthFilter</filter-class>
    </filter>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/admin/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/patient/*</url-pattern>
    </filter-mapping>
    <filter-mapping>
        <filter-name>AuthFilter</filter-name>
        <url-pattern>/doctor/*</url-pattern>
    </filter-mapping>

    <!-- Login Servlet -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>com.healthsync.controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- Logout Servlet -->
    <servlet>
        <servlet-name>LogoutServlet</servlet-name>
        <servlet-class>com.healthsync.controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>LogoutServlet</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- Register Servlet -->
    <servlet>
        <servlet-name>RegisterServlet</servlet-name>
        <servlet-class>com.healthsync.controller.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>RegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- Patient Servlet -->
    <servlet>
        <servlet-name>PatientServlet</servlet-name>
        <servlet-class>com.healthsync.controller.PatientServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PatientServlet</servlet-name>
        <url-pattern>/patients/*</url-pattern>
    </servlet-mapping>

    <!-- Doctor Servlet -->
    <servlet>
        <servlet-name>DoctorServlet</servlet-name>
        <servlet-class>com.healthsync.controller.DoctorServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DoctorServlet</servlet-name>
        <url-pattern>/doctors/*</url-pattern>
    </servlet-mapping>
    <!-- Appointment Servlet -->
    <servlet>
        <servlet-name>AppointmentServlet</servlet-name>
        <servlet-class>com.healthsync.controller.AppointmentServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AppointmentServlet</servlet-name>
        <url-pattern>/appointments/*</url-pattern>
    </servlet-mapping>

    <!-- Patient Dashboard Servlet -->
    <servlet>
        <servlet-name>PatientDashboardServlet</servlet-name>
        <servlet-class>com.healthsync.controller.PatientDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PatientDashboardServlet</servlet-name>
        <url-pattern>/patient/dashboard</url-pattern>
        <url-pattern>/patient/my-appointments</url-pattern>
        <url-pattern>/patient/book-appointment</url-pattern>
    </servlet-mapping>

    <!-- User Settings Servlet -->
    <servlet>
        <servlet-name>UserSettingsServlet</servlet-name>
        <servlet-class>com.healthsync.controller.UserSettingsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UserSettingsServlet</servlet-name>
        <url-pattern>/patient/profile</url-pattern>
        <url-pattern>/doctor/profile</url-pattern>
    </servlet-mapping>

    <!-- Patient Medical Records Servlet -->
    <servlet>
        <servlet-name>PatientMedicalRecordsServlet</servlet-name>
        <servlet-class>com.healthsync.controller.PatientMedicalRecordsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PatientMedicalRecordsServlet</servlet-name>
        <url-pattern>/patient/medical-records</url-pattern>
    </servlet-mapping>

    <!-- Doctor Dashboard Servlet -->
    <servlet>
        <servlet-name>DoctorDashboardServlet</servlet-name>
        <servlet-class>com.healthsync.controller.DoctorDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DoctorDashboardServlet</servlet-name>
        <url-pattern>/doctor/dashboard</url-pattern>
        <url-pattern>/doctor/appointments</url-pattern>
        <url-pattern>/doctor/patients</url-pattern>
    </servlet-mapping>

    <!-- Doctor Patient Records Servlet -->
    <servlet>
        <servlet-name>PatientRecordsServlet</servlet-name>
        <servlet-class>com.healthsync.controller.PatientRecordsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>PatientRecordsServlet</servlet-name>
        <url-pattern>/doctor/patient-records</url-pattern>
    </servlet-mapping>


    <!-- Admin Dashboard Servlet -->
    <servlet>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <servlet-class>com.healthsync.controller.AdminDashboardServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AdminDashboardServlet</servlet-name>
        <url-pattern>/admin/dashboard</url-pattern>
        <url-pattern>/admin/manage-patients</url-pattern>
        <url-pattern>/admin/manage-doctors</url-pattern>
        <url-pattern>/admin/manage-appointments</url-pattern>
        <url-pattern>/admin/approve-user</url-pattern>
        <url-pattern>/admin/edit-patient</url-pattern>
        <url-pattern>/admin/edit-doctor</url-pattern>
        <url-pattern>/admin/update-patient</url-pattern>
        <url-pattern>/admin/update-doctor</url-pattern>
    </servlet-mapping>


</web-app>